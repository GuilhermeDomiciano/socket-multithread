# ── Chaves de API ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Modelos por provedor (cada modelo vira uma PISTA na corrida) ─
# Lista separada por vírgula. Cada item corre como uma pista própria
# (Name = "provedor:modelo", ex. openai:gpt-4o-mini). Reusa a mesma chave.
# Vazio → cai no modelo default do provedor.
# Custo: 'fastest' dispara N chamadas em paralelo e o benchmark 2N — comece com 2.
# Modelos atuais (jun/2026). Gemini Flash/Flash-Lite têm free-tier; OpenAI é pago.
OPENAI_MODELS=gpt-5.4-mini,gpt-5.4
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-3.5-flash
# ANTHROPIC_MODELS=claude-...   # (não pesquisado; preencha com um modelo Claude atual)

# Legado: GEMINI_MODEL (singular) ainda funciona como default do Gemini se
# GEMINI_MODELS estiver vazio. Evite gemini-2.0-flash (free-tier zero → HTTP 429).
# GEMINI_MODEL=gemini-2.5-flash

# ── Estratégia de roteamento ────────────────────────────────────
# fastest   → dispara todos em paralelo, retorna o primeiro a responder
# cheapest  → escolhe o mais barato (estimativa por tokens), cai em fallback se falhar
# fallback  → tenta em ordem sequencial
PROXY_STRATEGY=fastest

# ── Ordem de prioridade (usado por fallback e cheapest) ─────────
PROXY_FALLBACK_ORDER=openai,gemini

# ── Servidor ────────────────────────────────────────────────────
PROXY_PORT=8080
PROXY_TIMEOUT_MS=5000
