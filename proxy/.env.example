# ── Chaves de API ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── Estratégia de roteamento ────────────────────────────────────
# fastest   → dispara todos em paralelo, retorna o primeiro a responder
# cheapest  → escolhe o mais barato (estimativa por tokens), cai em fallback se falhar
# fallback  → tenta em ordem sequencial
PROXY_STRATEGY=fastest

# ── Ordem de prioridade (usado por fallback e cheapest) ─────────
PROXY_FALLBACK_ORDER=openai,gemini

# ── Servidor ────────────────────────────────────────────────────
PROXY_PORT=8080
PROXY_TIMEOUT_MS=5000
